---
import SwarmHero from "./SwarmHero.astro";
---

<section
  class="home-stage boho-section home-motion-scope"
  aria-labelledby="home-stage-title"
>
  <div class="home-stage__grid">
    <div class="home-stage__copy">
      <p class="boho-kicker" data-home-reveal>Boho Digital</p>
      <h1 id="home-stage-title" data-home-reveal>
        SEO, websites, and growth systems without the agency fog.
      </h1>
      <p class="home-stage__subtitle" data-home-reveal>
        Boho Digital is a lean, research-driven growth studio for organic
        search, website systems, analytics, provider transfers, monthly support,
        and urgent digital cleanup.
      </p>
      <div class="home-stage__actions" data-home-reveal>
        <a class="boho-button boho-button--primary" href="/contact/"
          >Get a Growth Audit</a
        >
        <a
          class="boho-button boho-button--ghost"
          href="/services/monthly-growth-retainer/"
        >
          See Monthly Support
        </a>
        <a class="boho-button boho-button--danger" href="/contact/"
          >Request Rush Support</a
        >
      </div>
      <div class="home-stage__lines" data-home-reveal>
        <p>
          Every market has different search behavior, competitors, buyer doubts,
          and conversion paths. We research the landscape before prescribing the
          work.
        </p>
        <p>
          Internal systems, automation-assisted workflows, and low overhead help
          us move fast without making you pay for agency bloat.
        </p>
        <p>
          No guaranteed-ranking spells. No mystery dashboards. No vendor
          lock-in. Just useful work, clear priorities, and receipts.
        </p>
      </div>
    </div>
    <SwarmHero />
  </div>
</section>

<style>
  .home-stage {
    background:
      linear-gradient(90deg, rgb(244 190 62 / 9%) 1px, transparent 1px),
      linear-gradient(rgb(244 190 62 / 7%) 1px, transparent 1px),
      radial-gradient(
        circle at 72% 24%,
        rgb(244 190 62 / 20%),
        transparent 24rem
      ),
      linear-gradient(135deg, #050505 0%, #0d0b07 45%, #060606 100%);
    background-size:
      76px 76px,
      76px 76px,
      auto,
      auto;
    border-bottom: 1px solid rgb(244 190 62 / 18%);
    min-height: calc(100vh - 74px);
    overflow: hidden;
    position: relative;
  }

  .home-stage::before {
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgb(244 190 62 / 13%) 45%,
      transparent 70%
    );
    content: "";
    height: 160%;
    left: -30%;
    opacity: 0.6;
    position: absolute;
    top: -50%;
    transform: rotate(-14deg);
    width: 42%;
  }

  .home-stage__grid {
    align-items: center;
    display: grid;
    gap: clamp(2rem, 5vw, 5rem);
    grid-template-columns: minmax(0, 0.94fr) minmax(22rem, 1.06fr);
    margin: 0 auto;
    max-width: 1260px;
    min-height: calc(100vh - 74px);
    padding: clamp(4rem, 8vw, 7rem) 1.25rem;
    position: relative;
    z-index: 1;
  }

  .home-stage__copy {
    max-width: 720px;
  }

  h1 {
    color: var(--boho-cream);
    font-family: var(--boho-display);
    font-size: clamp(3.5rem, 7vw, 7.1rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.88;
    margin: 1.2rem 0 1.3rem;
    text-wrap: balance;
  }

  .home-stage__subtitle {
    color: rgb(248 241 223 / 86%);
    font-size: clamp(1.08rem, 1.7vw, 1.35rem);
    line-height: 1.55;
    max-width: 46rem;
  }

  .home-stage__lines {
    border-left: 3px solid var(--boho-honey);
    display: grid;
    gap: 0.8rem;
    margin-top: 1.65rem;
    padding-left: 1rem;
  }

  .home-stage__lines p {
    color: rgb(248 241 223 / 74%);
    font-size: 0.98rem;
    line-height: 1.55;
    margin: 0;
  }

  .home-stage__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  @media (max-width: 980px) {
    .home-stage__grid {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 4.5rem;
    }

    .home-stage {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .home-stage__grid {
      padding-inline: 1rem;
    }

    h1 {
      font-size: clamp(3rem, 15.5vw, 4.9rem);
    }

    .home-stage__actions {
      display: grid;
    }
  }
</style>
