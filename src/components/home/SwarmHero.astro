---
const nodes = [
  { label: "Market", x: 86, y: 74 },
  { label: "Search", x: 264, y: 44 },
  { label: "Site", x: 424, y: 86 },
  { label: "Audit", x: 470, y: 256 },
  { label: "Fix", x: 356, y: 420 },
  { label: "Monthly", x: 172, y: 430 },
  { label: "Rush", x: 58, y: 300 },
  { label: "Receipts", x: 110, y: 170 },
];
---

<div class="swarm-hero" aria-label="Research engine command diagram">
  <div class="swarm-hero__shell">
    <div class="swarm-hero__hud">
      <span>Hive command</span>
      <span>Research live</span>
    </div>
    <svg
      class="swarm-hero__svg"
      viewBox="0 0 540 500"
      role="img"
      aria-labelledby="swarm-title swarm-desc"
    >
      <title id="swarm-title">Boho research engine</title>
      <desc id="swarm-desc">
        A central research engine connected to market, search, site, audit, fix,
        monthly, rush, and receipts nodes.
      </desc>
      <defs>
        <radialGradient id="swarmGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#ffe08a" stop-opacity="0.92"></stop>
          <stop offset="62%" stop-color="#f4be3e" stop-opacity="0.24"></stop>
          <stop offset="100%" stop-color="#f4be3e" stop-opacity="0"></stop>
        </radialGradient>
      </defs>

      <path
        class="swarm-ring"
        d="M270 52a198 198 0 1 1 0 396a198 198 0 1 1 0 -396"></path>
      <path
        class="swarm-ring swarm-ring--inner"
        d="M270 130a120 120 0 1 1 0 240a120 120 0 1 1 0 -240"></path>

      {
        nodes.map((node) => (
          <path class="swarm-path" d={`M270 250 L${node.x} ${node.y}`} />
        ))
      }

      <g class="swarm-center">
        <circle cx="270" cy="250" r="82" fill="url(#swarmGlow)"></circle>
        <polygon
          points="270,161 348,205 348,295 270,339 192,295 192,205"
          fill="#11100b"
          stroke="#f4be3e"
          stroke-width="2"></polygon>
        <text x="270" y="238" text-anchor="middle">Research</text>
        <text x="270" y="266" text-anchor="middle">Engine</text>
      </g>

      {
        nodes.map((node) => (
          <g class="swarm-node" transform={`translate(${node.x} ${node.y})`}>
            <circle class="swarm-node__halo" r="24" />
            <circle class="swarm-node__core" r="9" />
            <text y="42" text-anchor="middle">
              {node.label}
            </text>
          </g>
        ))
      }

      <circle
        class="swarm-travel-dot swarm-travel-dot--one"
        cx="270"
        cy="250"
        r="4"></circle>
      <circle
        class="swarm-travel-dot swarm-travel-dot--two"
        cx="270"
        cy="250"
        r="3.2"></circle>
      <circle
        class="swarm-travel-dot swarm-travel-dot--three"
        cx="270"
        cy="250"
        r="3.2"></circle>
    </svg>
    <div class="swarm-hero__ticker" aria-hidden="true">
      <span>Research</span>
      <span>Diagnose</span>
      <span>Fix</span>
      <span>Maintain</span>
      <span>Rush</span>
      <span>Document</span>
    </div>
  </div>
</div>

<style>
  .swarm-hero {
    min-width: 0;
    position: relative;
  }

  .swarm-hero__shell {
    background:
      linear-gradient(145deg, rgb(248 241 223 / 10%), transparent 32%),
      radial-gradient(
        circle at 50% 45%,
        rgb(244 190 62 / 16%),
        transparent 24rem
      ),
      #0d0c08;
    border: 1px solid rgb(244 190 62 / 34%);
    border-radius: 0.5rem;
    box-shadow:
      0 1.5rem 5rem rgb(0 0 0 / 55%),
      inset 0 0 0 1px rgb(248 241 223 / 8%);
    overflow: hidden;
    padding: clamp(1rem, 3vw, 1.65rem);
    position: relative;
  }

  .swarm-hero__shell::before {
    background-image:
      linear-gradient(
        30deg,
        rgb(244 190 62 / 11%) 12%,
        transparent 12.5%,
        transparent 87%,
        rgb(244 190 62 / 11%) 87.5%,
        rgb(244 190 62 / 11%)
      ),
      linear-gradient(
        150deg,
        rgb(244 190 62 / 11%) 12%,
        transparent 12.5%,
        transparent 87%,
        rgb(244 190 62 / 11%) 87.5%,
        rgb(244 190 62 / 11%)
      ),
      linear-gradient(
        30deg,
        rgb(244 190 62 / 11%) 12%,
        transparent 12.5%,
        transparent 87%,
        rgb(244 190 62 / 11%) 87.5%,
        rgb(244 190 62 / 11%)
      ),
      linear-gradient(
        150deg,
        rgb(244 190 62 / 11%) 12%,
        transparent 12.5%,
        transparent 87%,
        rgb(244 190 62 / 11%) 87.5%,
        rgb(244 190 62 / 11%)
      );
    background-position:
      0 0,
      0 0,
      28px 49px,
      28px 49px;
    background-size: 56px 98px;
    content: "";
    inset: 0;
    opacity: 0.34;
    position: absolute;
  }

  .swarm-hero__hud,
  .swarm-hero__ticker,
  .swarm-hero__svg {
    position: relative;
    z-index: 1;
  }

  .swarm-hero__hud {
    align-items: center;
    color: var(--boho-honey-soft);
    display: flex;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 800;
    justify-content: space-between;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .swarm-hero__svg {
    display: block;
    height: auto;
    margin: 0 auto;
    max-width: 100%;
    overflow: visible;
  }

  .swarm-ring,
  .swarm-path {
    fill: none;
    stroke: rgb(244 190 62 / 44%);
    stroke-width: 1.5;
  }

  .swarm-ring {
    stroke-dasharray: 6 12;
  }

  .swarm-ring--inner {
    stroke: rgb(248 241 223 / 18%);
  }

  .swarm-path {
    stroke: rgb(244 190 62 / 54%);
  }

  .swarm-center text,
  .swarm-node text {
    fill: var(--boho-cream);
    font-family: var(--boho-display);
    font-weight: 800;
    letter-spacing: 0.03em;
  }

  .swarm-center text {
    font-size: 25px;
  }

  .swarm-node__halo {
    fill: rgb(244 190 62 / 14%);
    stroke: rgb(244 190 62 / 52%);
  }

  .swarm-node__core,
  .swarm-travel-dot {
    fill: var(--boho-honey);
  }

  .swarm-node text {
    font-size: 14px;
  }

  .swarm-travel-dot {
    filter: drop-shadow(0 0 10px rgb(244 190 62 / 82%));
  }

  .swarm-travel-dot--one {
    animation: travelOne 5.2s linear infinite;
  }

  .swarm-travel-dot--two {
    animation: travelTwo 6.4s linear infinite;
  }

  .swarm-travel-dot--three {
    animation: travelThree 7.2s linear infinite;
  }

  .swarm-hero__ticker {
    border-top: 1px solid rgb(244 190 62 / 22%);
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(6, 1fr);
    padding-top: 1rem;
  }

  .swarm-hero__ticker span {
    color: rgb(248 241 223 / 74%);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.66rem;
    font-weight: 800;
    text-align: center;
    text-transform: uppercase;
  }

  @keyframes travelOne {
    0%,
    100% {
      transform: translate(0, 0);
    }
    35% {
      transform: translate(154px, -164px);
    }
    70% {
      transform: translate(-98px, -176px);
    }
  }

  @keyframes travelTwo {
    0%,
    100% {
      transform: translate(0, 0);
    }
    35% {
      transform: translate(-212px, 50px);
    }
    70% {
      transform: translate(86px, 170px);
    }
  }

  @keyframes travelThree {
    0%,
    100% {
      transform: translate(0, 0);
    }
    35% {
      transform: translate(154px, 6px);
    }
    70% {
      transform: translate(-160px, 180px);
    }
  }

  @media (max-width: 640px) {
    .swarm-hero__ticker {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
