---
const panels = [
  {
    label: "Audit",
    title: "Map the market and the mess.",
    body: "Start with a research-driven SEO Growth Audit when you need to understand your market, competitors, site problems, content gaps, tracking issues, provider risks, and next useful fixes.",
    signals: [
      "Market scan",
      "Competitor review",
      "Technical SEO",
      "Priority map",
    ],
    cta: "Start with an audit",
    href: "/services/seo-growth-audit/",
  },
  {
    label: "Monthly",
    title: "Keep the hive moving.",
    body: "Monthly Growth Support keeps SEO, content, analytics, monitoring, implementation, and reporting moving without long-contract fog.",
    signals: [
      "Market watch",
      "Technical watchlist",
      "Content improvements",
      "Reporting notes",
    ],
    cta: "See monthly support",
    href: "/services/monthly-growth-retainer/",
  },
  {
    label: "Rush",
    title: "Stabilize the swarm.",
    body: "Rush Support is premium, availability-based triage for urgent website, SEO, analytics, redirect, provider-transfer, and launch problems.",
    signals: ["Fast triage", "Risk map", "Fix window", "Receipts"],
    cta: "Request rush support",
    href: "/contact/",
  },
];
---

<section
  class="signal-deck boho-section home-motion-scope"
  aria-labelledby="signal-deck-title"
>
  <div class="boho-section__inner">
    <div class="signal-deck__header" data-home-reveal>
      <p class="boho-kicker">Entry paths</p>
      <h2 id="signal-deck-title">Start where the signal is loudest.</h2>
      <p>
        You do not need to diagnose the whole hive before taking the first step.
        Pick the path that matches what is happening right now.
      </p>
    </div>

    <div class="signal-deck__panels" data-signal-deck>
      {
        panels.map((panel, index) => (
          <article
            class={`signal-panel ${index === 0 ? "is-active" : ""}`}
            data-signal-panel
            tabindex="0"
          >
            <div class="signal-panel__number">
              {String(index + 1).padStart(2, "0")}
            </div>
            <div class="signal-panel__main">
              <p>{panel.label}</p>
              <h3>{panel.title}</h3>
              <span>{panel.body}</span>
            </div>
            <div
              class="signal-panel__signals"
              aria-label={`${panel.label} signals`}
            >
              {panel.signals.map((signal) => (
                <span>{signal}</span>
              ))}
            </div>
            <a href={panel.href}>{panel.cta}</a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .signal-deck {
    background:
      radial-gradient(
        circle at 12% 12%,
        rgb(244 190 62 / 12%),
        transparent 28rem
      ),
      #0b0b08;
    border-bottom: 1px solid rgb(244 190 62 / 14%);
  }

  .signal-deck__header {
    display: grid;
    gap: 1rem;
    max-width: 880px;
  }

  .signal-deck__header p:last-child {
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 48rem;
  }

  .signal-deck__panels {
    display: grid;
    gap: 1rem;
    margin-top: 2.2rem;
  }

  .signal-panel {
    align-items: stretch;
    background:
      linear-gradient(90deg, rgb(244 190 62 / 10%), transparent 42%), #15140f;
    border: 1px solid rgb(248 241 223 / 14%);
    border-left: 0.45rem solid rgb(244 190 62 / 48%);
    color: var(--boho-cream);
    display: grid;
    gap: 1rem;
    grid-template-columns: 4.25rem minmax(0, 1.35fr) minmax(12rem, 0.82fr) auto;
    min-height: 11rem;
    outline: none;
    padding: clamp(1.1rem, 2vw, 1.7rem);
    position: relative;
    transition:
      background 200ms ease,
      border-color 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }

  .signal-panel::after {
    background: linear-gradient(
      90deg,
      transparent,
      rgb(244 190 62 / 45%),
      transparent
    );
    bottom: 0;
    content: "";
    height: 1px;
    left: 0;
    opacity: 0;
    position: absolute;
    right: 0;
    transition: opacity 200ms ease;
  }

  .signal-panel:hover,
  .signal-panel:focus-visible,
  .signal-panel.is-active {
    background:
      linear-gradient(90deg, rgb(244 190 62 / 21%), transparent 55%), #1b180f;
    border-color: rgb(244 190 62 / 48%);
    box-shadow: 0 1.2rem 4rem rgb(0 0 0 / 38%);
    transform: translateX(0.45rem);
  }

  .signal-panel:hover::after,
  .signal-panel:focus-visible::after,
  .signal-panel.is-active::after {
    opacity: 1;
  }

  .signal-panel__number {
    color: rgb(244 190 62 / 70%);
    font-family: var(--boho-display);
    font-size: clamp(2.2rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 0.85;
  }

  .signal-panel__main {
    display: grid;
    gap: 0.55rem;
  }

  .signal-panel__main p {
    color: var(--boho-honey-soft);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    margin: 0;
    text-transform: uppercase;
  }

  .signal-panel h3 {
    color: var(--boho-cream);
    font-size: clamp(1.8rem, 3.6vw, 3.9rem);
    font-weight: 900;
    line-height: 0.95;
    margin: 0;
  }

  .signal-panel__main span {
    color: rgb(248 241 223 / 73%);
    line-height: 1.55;
    max-width: 39rem;
  }

  .signal-panel__signals {
    align-content: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .signal-panel__signals span {
    border: 1px solid rgb(244 190 62 / 22%);
    color: rgb(248 241 223 / 78%);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 800;
    padding: 0.45rem 0.55rem;
    text-transform: uppercase;
  }

  .signal-panel a {
    align-self: center;
    color: var(--boho-honey-soft);
    font-family: var(--boho-display);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (max-width: 920px) {
    .signal-panel {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .signal-panel:hover,
    .signal-panel:focus-visible,
    .signal-panel.is-active {
      transform: translateY(-0.25rem);
    }

    .signal-panel a {
      white-space: normal;
    }
  }
</style>
