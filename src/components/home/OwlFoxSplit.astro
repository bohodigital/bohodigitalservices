---
const owlChips = [
  "Technical SEO",
  "Search intent",
  "Redirect map",
  "Provider lock-in",
  "Search Console",
  "Vanity metrics",
];
const foxChips = [
  "Guaranteed rankings",
  "Link farms",
  "Black-box SEO",
  "Provider lock-in",
  "Reporting theater",
];
---

<section
  class="owl-fox boho-section home-motion-scope"
  aria-labelledby="owl-fox-title"
>
  <div class="boho-section__inner">
    <div class="owl-fox__header" data-home-reveal>
      <p class="boho-kicker">Knowledge layer</p>
      <h2 id="owl-fox-title">
        Clear language on one side. Fox traps on the other.
      </h2>
    </div>

    <div class="owl-fox__split">
      <article class="knowledge-panel knowledge-panel--owl" data-home-reveal>
        <div class="knowledge-panel__mark" aria-hidden="true">OWL</div>
        <h3>Ask the Owl</h3>
        <p>
          Plain-English definitions for SEO, analytics, provider-transfer,
          market research, and AI workflow terms.
        </p>
        <div class="knowledge-panel__chips" data-chip-group>
          {owlChips.map((chip) => <span>{chip}</span>)}
        </div>
        <a
          class="boho-button boho-button--primary"
          href="/ask-the-owl/dictionary/"
        >
          Open the Dictionary
        </a>
      </article>

      <article class="knowledge-panel knowledge-panel--fox" data-home-reveal>
        <div class="knowledge-panel__mark" aria-hidden="true">FOX</div>
        <h3>Shortcut Fox</h3>
        <p>
          A field guide to cheap promises, black-box SEO, link schemes,
          reporting theater, and vendor lock-in.
        </p>
        <div class="knowledge-panel__chips" data-chip-group>
          {foxChips.map((chip) => <span>{chip}</span>)}
        </div>
        <a class="boho-button boho-button--danger" href="/bad-seo-field-guide/">
          Open the Field Guide
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .owl-fox {
    background:
      linear-gradient(
        90deg,
        rgb(244 190 62 / 10%),
        transparent 45%,
        rgb(255 122 47 / 11%)
      ),
      #090806;
    border-bottom: 1px solid rgb(244 190 62 / 13%);
  }

  .owl-fox__header {
    display: grid;
    gap: 1rem;
    max-width: 920px;
  }

  .owl-fox__split {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 2rem;
  }

  .knowledge-panel {
    border: 1px solid rgb(248 241 223 / 14%);
    display: grid;
    min-height: 30rem;
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2rem);
    position: relative;
  }

  .knowledge-panel::before {
    content: "";
    inset: 0;
    opacity: 0.24;
    pointer-events: none;
    position: absolute;
  }

  .knowledge-panel--owl {
    background: #121108;
    box-shadow: inset 0 0 6rem rgb(244 190 62 / 10%);
  }

  .knowledge-panel--owl::before {
    background: radial-gradient(
      circle at 18% 22%,
      rgb(244 190 62 / 46%),
      transparent 20rem
    );
  }

  .knowledge-panel--fox {
    background: #120d08;
    box-shadow: inset 0 0 6rem rgb(255 122 47 / 9%);
  }

  .knowledge-panel--fox::before {
    animation: warningPulse 3.8s ease-in-out infinite;
    background: radial-gradient(
      circle at 82% 24%,
      rgb(255 122 47 / 42%),
      transparent 20rem
    );
  }

  .knowledge-panel > * {
    position: relative;
    z-index: 1;
  }

  .knowledge-panel__mark {
    color: rgb(248 241 223 / 8%);
    font-family: var(--boho-display);
    font-size: clamp(5rem, 15vw, 11rem);
    font-weight: 900;
    line-height: 0.78;
    margin-bottom: auto;
  }

  .knowledge-panel h3 {
    color: var(--boho-cream);
    font-size: clamp(2.2rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 0.92;
    margin: 0;
  }

  .knowledge-panel p {
    font-size: 1.03rem;
    line-height: 1.65;
    margin-top: 1rem;
    max-width: 34rem;
  }

  .knowledge-panel__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.48rem;
    margin: 1.3rem 0 1.6rem;
  }

  .knowledge-panel__chips span {
    border: 1px solid rgb(248 241 223 / 16%);
    color: rgb(248 241 223 / 74%);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    font-weight: 850;
    padding: 0.48rem 0.56rem;
    text-transform: uppercase;
  }

  .knowledge-panel a {
    align-self: end;
    justify-self: start;
  }

  @keyframes warningPulse {
    0%,
    100% {
      opacity: 0.16;
    }
    50% {
      opacity: 0.34;
    }
  }

  @media (max-width: 820px) {
    .owl-fox__split {
      grid-template-columns: 1fr;
    }
  }
</style>
