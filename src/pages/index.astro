---
import Layout from "~/layouts/PageLayout.astro";
import HomeStage from "~/components/home/HomeStage.astro";
import SignalDeck from "~/components/home/SignalDeck.astro";
import ResearchRadar from "~/components/home/ResearchRadar.astro";
import MonthlyOpsLoop from "~/components/home/MonthlyOpsLoop.astro";
import RushIncidentBoard from "~/components/home/RushIncidentBoard.astro";
import OwlFoxSplit from "~/components/home/OwlFoxSplit.astro";
import ConversionDock from "~/components/home/ConversionDock.astro";

const metadata = {
  title: "Boho Digital",
  ignoreTitleTemplate: true,
  description:
    "A lean, research-driven growth studio for SEO, websites, analytics, monthly support, provider transfers, and rush digital cleanup.",
};
---

<Layout metadata={metadata}>
  <div class="boho-home boho-home--rebel">
    <HomeStage />
    <SignalDeck />
    <ResearchRadar />
    <MonthlyOpsLoop />
    <RushIncidentBoard />
    <OwlFoxSplit />
    <ConversionDock />
  </div>
</Layout>

<script>
  import "~/scripts/home-experience";
</script>

<style>
  :global(.boho-home) {
    --boho-black: #060606;
    --boho-ink: #10100d;
    --boho-charcoal: #171713;
    --boho-panel: #1d1a12;
    --boho-line: rgb(244 190 62 / 34%);
    --boho-honey: #f4be3e;
    --boho-honey-soft: #ffe08a;
    --boho-cream: #f8f1df;
    --boho-muted: rgb(248 241 223 / 72%);
    --boho-warning: #ff7a2f;
    --boho-green: #97a66b;
    --boho-display:
      "Space Grotesk Variable", "Inter Variable", ui-sans-serif, system-ui,
      sans-serif;
    background:
      radial-gradient(
        circle at 20% 0%,
        rgb(244 190 62 / 14%),
        transparent 34rem
      ),
      radial-gradient(
        circle at 90% 18%,
        rgb(255 122 47 / 10%),
        transparent 30rem
      ),
      var(--boho-black);
    color: var(--boho-cream);
    font-family: "Inter Variable", ui-sans-serif, system-ui, sans-serif;
    overflow: hidden;
  }

  :global(.boho-home *) {
    box-sizing: border-box;
  }

  :global(.boho-home a) {
    color: inherit;
  }

  :global(.boho-button) {
    align-items: center;
    border: 1px solid rgb(248 241 223 / 20%);
    border-radius: 0.35rem;
    display: inline-flex;
    font-family: var(--boho-display);
    font-size: 0.82rem;
    font-weight: 800;
    gap: 0.55rem;
    justify-content: center;
    letter-spacing: 0.06em;
    min-height: 3rem;
    padding: 0.9rem 1.1rem;
    text-transform: uppercase;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  :global(.boho-button:hover),
  :global(.boho-button:focus-visible) {
    border-color: var(--boho-honey);
    box-shadow: 0 0 0 3px rgb(244 190 62 / 18%);
    transform: translateY(-2px);
  }

  :global(.boho-button--primary) {
    background: var(--boho-honey);
    border-color: var(--boho-honey);
    color: #090806;
  }

  :global(.boho-button--ghost) {
    background: rgb(248 241 223 / 7%);
    color: var(--boho-cream);
  }

  :global(.boho-button--danger) {
    background: rgb(255 122 47 / 14%);
    border-color: rgb(255 122 47 / 55%);
    color: var(--boho-cream);
  }

  :global(.boho-section) {
    position: relative;
  }

  :global(.boho-section__inner) {
    margin: 0 auto;
    max-width: 1180px;
    padding: 6rem 1.25rem;
    position: relative;
    width: 100%;
    z-index: 1;
  }

  :global(.boho-kicker) {
    color: var(--boho-honey-soft);
    display: inline-flex;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  :global(.boho-home h1),
  :global(.boho-home h2),
  :global(.boho-home h3) {
    font-family: var(--boho-display);
    letter-spacing: 0;
  }

  :global(.boho-home h2) {
    font-size: clamp(2.4rem, 5.8vw, 5.9rem);
    font-weight: 850;
    line-height: 0.92;
  }

  :global(.boho-home p) {
    color: var(--boho-muted);
  }

  @media (max-width: 640px) {
    :global(.boho-section__inner) {
      padding: 4.25rem 1rem;
    }

    :global(.boho-button) {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.boho-home *),
    :global(.boho-home *::before),
    :global(.boho-home *::after) {
      animation-duration: 1ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 1ms !important;
    }
  }
</style>
